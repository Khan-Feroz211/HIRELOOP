# ═══════════════════════════════════════════════════════
# HireLoop PK — Environment Variables Example
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# App
APP_NAME=HireLoop PK
APP_ENV=development
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (Supabase free tier in dev)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hireloop
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/hireloop

# Redis (Upstash free tier in dev)
REDIS_URL=redis://localhost:6379

# Claude AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Gmail API
GMAIL_CREDENTIALS_FILE=gmail_credentials.json
GMAIL_TOKEN_FILE=gmail_token.json

# Job Scraping
APIFY_API_TOKEN=your-apify-token
SERPAPI_KEY=your-serpapi-key

# Email Sending (Resend.com)
RESEND_API_KEY=re_your-resend-key
FROM_EMAIL=noreply@hireloop.pk

# Payments (Safepay Pakistan)
SAFEPAY_PUBLIC_KEY=your-safepay-public-key
SAFEPAY_SECRET_KEY=your-safepay-secret-key

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://hireloop.pk

# n8n Webhook Secret
WEBHOOK_SECRET=your-webhook-secret-here
